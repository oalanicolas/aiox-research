{
  "name": "aiox-research",
  "version": "0.1.0",
  "private": false,
  "description": "Local-first Open Research workbench and observatory for research artifacts.",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:research-core": "node --experimental-strip-types --test packages/research-core/src/__tests__/*.test.mjs",
    "fitness:research-core": "node --experimental-strip-types scripts/check-fitness.ts",
    "research-core:fixture": "node --experimental-strip-types packages/research-core/src/cli.ts",
    "init": "node scripts/init-observatory.mjs",
    "init:test": "node scripts/test/test-init.mjs",
    "repair:legacy": "node scripts/repair-legacy-research-runs.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
